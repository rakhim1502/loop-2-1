# Backend Environment Variables

PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/harry-potter-academy

# JWT
JWT_SECRET=harry-potter-academy-super-secret-jwt-key-2024-premium-educational-platform
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=harry-potter-academy-refresh-token-secret-key-2024
JWT_REFRESH_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Harry Potter Academy <info@harrypotteracademy.com>

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Payment APIs (Click, Payme, Uzum Bank)
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key

PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

UZUM_BANK_API_KEY=your-uzum-bank-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
